{
  "name": "hasanhub-cloudflare",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "db:validate": "node --loader ts-node/esm scripts/validate-db.ts",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply hasanhub --local",
    "db:migrate:remote": "wrangler d1 migrations apply hasanhub --remote",
    "db:studio": "drizzle-kit studio",
    "db:studio:remote": "NODE_ENV=production drizzle-kit studio",
    "db:import:remote-to-local": "bun ./scripts/db-import-remote-to-local.ts",
    "db:import:local-to-remote": "bun ./scripts/db-import-local-to-remote.ts"
  },
  "dependencies": {
    "@epic-web/cachified": "^4.0.0",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@xmldom/xmldom": "^0.9.7",
    "chalk": "^5.6.2",
    "classnames": "^2.3.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.44.5",
    "html-entities": "^2.3.3",
    "isbot": "^5.1.31",
    "iso8601-duration": "^2.1.1",
    "lucide-react": "^0.536.0",
    "ora": "^9.3.0",
    "pretty-cache-header": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "rss-parser": "^3.12.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tiny-invariant": "^1.2.0",
    "vaul": "^1.1.2",
    "youtube.ts": "^0.2.9",
    "zod": "^3.16.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.12.3",
    "@cloudflare/workers-types": "^4.20240909.0",
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "better-sqlite3": "^11.7.0",
    "tailwindcss": "^4.1.13",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.62.0"
  }
}